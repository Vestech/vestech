---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { statusLabel } from '../lib/postStatus';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const groups = {
  in_review: posts.filter((post) => post.data.status === 'in_review'),
  rework: posts.filter((post) => post.data.status === 'rework'),
  draft: posts.filter((post) => post.data.status === 'draft'),
  published: posts.filter((post) => post.data.status === 'published'),
};

const sections = [
  {
    key: 'in_review',
    title: 'Ke schválení',
    description: 'Články připravené na tvoje rozhodnutí.',
  },
  {
    key: 'rework',
    title: 'Vráceno k přepracování',
    description: 'Články, které jsi poslal zpět s připomínkami.',
  },
  {
    key: 'draft',
    title: 'Drafty',
    description: 'Rozpracované články, které ještě nejsou připravené na review.',
  },
  {
    key: 'published',
    title: 'Publikováno',
    description: 'Články, které jsou už veřejně venku.',
  },
] as const;
---
<BaseLayout title="Admin" lang="cs">
  <section id="admin-login" class="max-w-xl mx-auto px-4 py-20">
    <div class="card-glass rounded-2xl p-8 space-y-6">
      <div class="space-y-3">
        <div class="tag w-fit">Uzamčená sekce</div>
        <h1 class="text-3xl md:text-4xl font-black text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
          Přihlášení do administrace
        </h1>
        <p class="text-[#c8e6c9] leading-relaxed">
          Admin sekce není veřejně přístupná. Pro zobrazení review dashboardu zadej administrační heslo.
        </p>
      </div>

      <form id="admin-login-form" class="space-y-4">
        <div class="space-y-2">
          <label for="admin-password" class="text-sm text-[#7ab87a]">Admin heslo</label>
          <input
            id="admin-password"
            type="password"
            autocomplete="current-password"
            class="w-full rounded-lg border border-[#00ff41]/20 bg-[#08110d] px-4 py-3 text-[#e8f5e9] outline-none focus:border-[#00ff41]"
            placeholder="Zadej heslo"
          />
        </div>
        <button type="submit" class="btn-primary w-full justify-center text-center">Odemknout admin</button>
        <p id="admin-login-error" class="hidden text-sm text-red-300"></p>
      </form>

      <div class="rounded-xl border border-amber-500/20 bg-amber-500/8 px-4 py-3 text-sm text-amber-100 leading-relaxed">
        Tohle je lehká klientská ochrana vhodná pro aktuální statický deploy. Pro silnější ochranu doporučuju další krok dát přes Cloudflare Access nebo server-side auth.
      </div>
    </div>
  </section>

  <section id="admin-dashboard" class="hidden max-w-6xl mx-auto px-4 py-16 space-y-10">
    <div class="space-y-4 max-w-3xl">
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div>
          <div class="tag w-fit">Admin sekce</div>
          <h1 class="text-4xl md:text-5xl font-black text-[#e8f5e9] mt-4" style="font-family:'Space Grotesk',sans-serif">
            Moderace článků před publikací
          </h1>
        </div>
        <button id="admin-logout" type="button" class="border border-[#00ff41]/30 hover:border-[#00ff41] text-[#00ff41] px-4 py-2 rounded text-sm font-semibold transition-colors">
          Odhlásit
        </button>
      </div>
      <p class="text-[#c8e6c9] leading-relaxed text-lg">
        Tady uvidíš všechny články podle stavu. Veřejný blog ukazuje jen články se stavem <strong>published</strong>.
        Když bude článek hotový na review, nastavím mu stav <strong>in_review</strong>. Ty si ho tady otevřeš,
        zkontroluješ a rozhodneš, jestli jde ven, nebo zpátky k přepracování.
      </p>
      <div class="card-glass rounded-xl p-5 text-sm text-[#c8e6c9] leading-relaxed">
        <strong class="text-[#00ff41]">Poznámka:</strong> Web je teď hostovaný jako statický Astro projekt na Cloudflare Pages.
        To znamená, že tahle admin sekce je reálný review dashboard, ale tlačítka Publish / Vrátit k přepracování zatím fungují
        přes změnu frontmatteru v repu a nový deploy. Pokud budeš chtít plně klikací workflow přímo z webu bez commitu,
        doplníme k tomu malý backend nebo GitHub API vrstvu.
      </div>
    </div>

    <div class="grid gap-8">
      {sections.map((section) => (
        <section class="space-y-4">
          <div class="flex items-center justify-between gap-4 flex-wrap">
            <div>
              <h2 class="text-2xl font-bold text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">{section.title}</h2>
              <p class="text-[#7ab87a] text-sm">{section.description}</p>
            </div>
            <span class="tag">{groups[section.key].length}</span>
          </div>

          {groups[section.key].length === 0 ? (
            <div class="card-glass rounded-xl p-5 text-[#7ab87a] text-sm">
              V téhle sekci teď nic není.
            </div>
          ) : (
            <div class="grid gap-4">
              {groups[section.key].map((post) => (
                <article class="card-glass rounded-xl p-5 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                  <div class="space-y-3 max-w-3xl">
                    <div class="flex flex-wrap gap-2 items-center">
                      <span class="tag">{post.data.lang.toUpperCase()}</span>
                      <span class="tag">{statusLabel(post.data.status, 'cs')}</span>
                      {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
                    </div>
                    <div>
                      <h3 class="text-xl font-bold text-[#e8f5e9]">{post.data.title}</h3>
                      <p class="text-[#c8e6c9] mt-2">{post.data.description}</p>
                    </div>
                    <div class="text-sm text-[#7ab87a] flex flex-wrap gap-3">
                      <span>Autor: {post.data.author}</span>
                      <span>Datum: {post.data.pubDate.toLocaleDateString('cs-CZ')}</span>
                      {post.data.readTime && <span>{post.data.readTime} min čtení</span>}
                    </div>
                    {post.data.reviewerNotes && (
                      <div class="rounded-lg border border-amber-500/30 bg-amber-500/8 px-4 py-3 text-sm text-amber-100">
                        <strong class="text-amber-300">Poznámka k review:</strong><br />
                        {post.data.reviewerNotes}
                      </div>
                    )}
                  </div>

                  <div class="flex flex-col gap-3 md:items-end md:min-w-[220px]">
                    <div class="btn-primary text-center opacity-80 cursor-default">
                      Preview v adminu
                    </div>
                    <div class="rounded-lg border border-[#00ff41]/20 bg-[#08110d] px-4 py-3 text-sm text-[#c8e6c9]">
                      <div><strong class="text-[#00ff41]">Publish:</strong> nastav `status: published`</div>
                      <div class="mt-2"><strong class="text-[#00e5cc]">Vrátit:</strong> nastav `status: rework` a doplň `reviewerNotes`</div>
                      <div class="mt-2"><strong class="text-[#00ff41]">Na schválení:</strong> nastav `status: in_review`</div>
                    </div>
                    <code class="text-xs text-[#7ab87a] break-all">src/content/blog/{post.id}.md</code>
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      var loginSection = document.getElementById('admin-login');
      var dashboardSection = document.getElementById('admin-dashboard');
      var form = document.getElementById('admin-login-form');
      var input = document.getElementById('admin-password');
      var error = document.getElementById('admin-login-error');
      var logout = document.getElementById('admin-logout');
      var secret = 'vestech-admin-2026';
      var storageKey = 'vestech.admin.unlocked';

      function showDashboard() {
        if (loginSection) loginSection.classList.add('hidden');
        if (dashboardSection) dashboardSection.classList.remove('hidden');
      }

      function showLogin() {
        if (dashboardSection) dashboardSection.classList.add('hidden');
        if (loginSection) loginSection.classList.remove('hidden');
      }

      try {
        if (sessionStorage.getItem(storageKey) === '1') {
          showDashboard();
        } else {
          showLogin();
        }
      } catch (e) {
        showLogin();
      }

      if (form && input) {
        form.addEventListener('submit', function (event) {
          event.preventDefault();
          if (input.value === secret) {
            try { sessionStorage.setItem(storageKey, '1'); } catch (e) {}
            if (error) {
              error.textContent = '';
              error.classList.add('hidden');
            }
            input.value = '';
            showDashboard();
            return;
          }
          if (error) {
            error.textContent = 'Neplatné heslo.';
            error.classList.remove('hidden');
          }
        });
      }

      if (logout) {
        logout.addEventListener('click', function () {
          try { sessionStorage.removeItem(storageKey); } catch (e) {}
          showLogin();
        });
      }
    })();
  </script>
</BaseLayout>
