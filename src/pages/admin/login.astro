---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Admin Login" lang="cs" noIndex>
  <section class="max-w-xl mx-auto px-4 py-20">
    <div class="card-glass rounded-2xl p-8 space-y-6">
      <div class="space-y-3">
        <div class="tag w-fit">Uzamčená sekce</div>
        <h1 class="text-3xl md:text-4xl font-black text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
          Přihlášení do administrace
        </h1>
      </div>

      <form action="/admin/login" method="post" class="space-y-4">
        <input id="admin-next" type="hidden" name="next" value="/admin" />
        <div class="space-y-2">
          <label for="admin-password" class="text-sm text-[#7ab87a]">Admin heslo</label>
          <input
            id="admin-password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            class="w-full rounded-lg border border-[#00ff41]/20 bg-[#08110d] px-4 py-3 text-[#e8f5e9] outline-none focus:border-[#00ff41]"
            placeholder="Zadej heslo"
          />
        </div>
        <button type="submit" class="btn-primary w-full justify-center text-center">Odemknout admin</button>
      </form>

      <p id="admin-login-error" class="hidden rounded-xl border px-4 py-3 text-sm leading-relaxed"></p>

    </div>
  </section>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(window.location.search);
      var next = params.get('next');
      var nextInput = document.getElementById('admin-next');
      var error = document.getElementById('admin-login-error');

      if (next && nextInput && next.charAt(0) === '/') {
        nextInput.value = next;
      }

      if (!error) return;

      var type = params.get('error');
      if (type === 'invalid') {
        error.textContent = 'Neplatné heslo. Zkus to znovu.';
      } else if (type === 'config') {
        error.textContent = 'Admin přihlášení není nakonfigurované. Nastav ADMIN_PASSWORD a ADMIN_SESSION_SECRET v Cloudflare Pages.';
      } else if (type === 'expired') {
        error.textContent = 'Session vypršela. Přihlas se znovu.';
      } else {
        return;
      }

      error.className = 'rounded-xl border border-red-500/30 bg-red-500/10 px-4 py-3 text-sm leading-relaxed text-red-200';
    })();
  </script>
</BaseLayout>
