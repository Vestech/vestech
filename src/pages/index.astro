---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Výzkum na hraně technologií" lang="cs">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden min-h-[70vh] md:min-h-[78vh] flex items-start">
    <div class="absolute inset-0 pointer-events-none" style="background-image:url('/images/hero-tree-tech.jpg'); background-size:cover; background-position:center center;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:
      linear-gradient(90deg, rgba(2,8,7,0.68) 0%, rgba(2,8,7,0.42) 34%, rgba(2,8,7,0.16) 58%, rgba(2,8,7,0.08) 100%),
      linear-gradient(180deg, rgba(2,8,7,0.22) 0%, rgba(2,8,7,0.08) 32%, rgba(2,8,7,0.32) 100%);"></div>
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none"></div>
    <canvas data-blue-flow class="absolute inset-0 w-full h-full pointer-events-none opacity-90" aria-hidden="true"></canvas>
        <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-14 pb-20 md:px-10 md:pt-20 md:pb-24 lg:px-14 lg:pt-24 lg:pb-28">
      <div class="max-w-2xl">
        <div class="tag w-fit mb-5">VesTech Research</div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
          <span class="text-[#f2fff3]">Výzkum na</span><br/>
          <span class="glow-green" style="color:#00ff41">hraně technologií</span>
        </h1>
        <p class="text-[#d7f5d9] text-lg md:text-xl leading-relaxed max-w-xl mb-8 drop-shadow-[0_2px_20px_rgba(0,0,0,0.45)]">
          AI, QA, Fintech a DevOps — pohledem praktiků z <span id="typewriter" class="text-[#00ff41] font-semibold">první linie</span><span class="typewriter-cursor"></span>.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/blog" class="btn-primary">Číst blog →</a>
          <a href="/about" class="text-[#d7f5d9] hover:text-[#00e5cc] transition-colors flex items-center gap-1 text-sm md:text-base">
            O nás →
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function () {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;


  /* ── Blue dots along circuit lines ── */
  (function () {
    var canvases = document.querySelectorAll('[data-blue-flow]');
    if (!canvases.length) return;

    function init(canvas) {
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var routes = [];
      var dots = [];

      function pt(x, y, w, h) { return { x: w * x, y: h * y }; }

      function makeRoute(points) {
        var total = 0;
        var segments = [];
        for (var i = 0; i < points.length - 1; i++) {
          var a = points[i], b = points[i + 1];
          var len = Math.hypot(b.x - a.x, b.y - a.y);
          segments.push({ a: a, b: b, len: len, start: total });
          total += len;
        }
        return { points: points, segments: segments, total: total };
      }

      function routePoint(route, t) {
        var d = ((t % 1) + 1) % 1 * route.total;
        for (var i = 0; i < route.segments.length; i++) {
          var s = route.segments[i];
          if (d <= s.start + s.len || i === route.segments.length - 1) {
            var local = s.len ? (d - s.start) / s.len : 0;
            return {
              x: s.a.x + (s.b.x - s.a.x) * local,
              y: s.a.y + (s.b.y - s.a.y) * local
            };
          }
        }
        return route.points[0];
      }

      function build() {
        var rect = canvas.getBoundingClientRect();
        var w = rect.width, h = rect.height;
        var dpr = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, Math.round(w * dpr));
        canvas.height = Math.max(1, Math.round(h * dpr));
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

        routes = [
          makeRoute([pt(0.60,0.08,w,h), pt(0.60,0.34,w,h), pt(0.73,0.34,w,h), pt(0.73,0.54,w,h), pt(0.84,0.54,w,h)]),
          makeRoute([pt(0.57,0.24,w,h), pt(0.68,0.24,w,h), pt(0.68,0.16,w,h), pt(0.82,0.16,w,h)]),
          makeRoute([pt(0.56,0.44,w,h), pt(0.68,0.44,w,h), pt(0.68,0.62,w,h), pt(0.82,0.62,w,h)]),
          makeRoute([pt(0.62,0.58,w,h), pt(0.75,0.58,w,h), pt(0.75,0.82,w,h), pt(0.88,0.82,w,h)]),
          makeRoute([pt(0.73,0.10,w,h), pt(0.73,0.30,w,h)]),
          makeRoute([pt(0.80,0.36,w,h), pt(0.92,0.36,w,h)]),
          makeRoute([pt(0.78,0.72,w,h), pt(0.93,0.72,w,h)])
        ];

        dots = [];
        for (var i = 0; i < routes.length; i++) {
          var count = i < 4 ? 2 : 1;
          for (var j = 0; j < count; j++) {
            dots.push({
              route: i,
              t: (j / count) + Math.random() * 0.08,
              dir: Math.random() > 0.5 ? 1 : -1,
              speed: 0.0009 + Math.random() * 0.0012,
              size: 1.35 + Math.random() * 0.8
            });
          }
        }
      }

      function draw(staticOnly) {
        var rect = canvas.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);
        if (staticOnly) return;

        for (var i = 0; i < dots.length; i++) {
          var dot = dots[i];
          dot.t += dot.speed * dot.dir;
          if (dot.t >= 1) { dot.t = 1; dot.dir = -1; }
          if (dot.t <= 0) { dot.t = 0; dot.dir = 1; }
          var p = routePoint(routes[dot.route], dot.t);
          var glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, dot.size * 5);
          glow.addColorStop(0, 'rgba(180,245,255,0.95)');
          glow.addColorStop(0.35, 'rgba(84,214,255,0.55)');
          glow.addColorStop(1, 'rgba(84,214,255,0)');
          ctx.fillStyle = glow;
          ctx.beginPath();
          ctx.arc(p.x, p.y, dot.size * 5, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = 'rgba(169,242,255,0.95)';
          ctx.beginPath();
          ctx.arc(p.x, p.y, dot.size, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      build();
      draw(true);
      window.addEventListener('resize', build);
      if (reduced) return;
      function tick() { draw(false); requestAnimationFrame(tick); }
      requestAnimationFrame(tick);
    }

    canvases.forEach(init);
  })();


  /* ── Typewriter ── */
  (function () {
    var words = ['první linie', 'umělé inteligence', 'QA testování', 'fintechu', 'bezpečnosti'];
    var el = document.getElementById('typewriter');
    if (!el) return;
    if (reduced) { el.textContent = words[0]; return; }
    var wi = 0, ci = words[0].length, deleting = false;
    function tick() {
      var word = words[wi];
      if (!deleting) {
        el.textContent = word.slice(0, ci + 1);
        ci++;
        if (ci === word.length) { deleting = true; setTimeout(tick, 1600); return; }
      } else {
        el.textContent = word.slice(0, ci - 1);
        ci--;
        if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
      }
      setTimeout(tick, deleting ? 52 : 88);
    }
    setTimeout(tick, 2200);
  })();
})();
</script>
