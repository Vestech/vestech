---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const csPosts = allPosts
  .filter(p => p.data.lang === 'cs')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const topics = ['AI', 'QA', 'Fintech', 'DevOps', 'Security', 'Testing', 'Automation'];
---
<BaseLayout title="Výzkum na hraně technologií" lang="cs">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden" style="min-height:520px;">
    <!-- Animated particle canvas -->
    <canvas id="hero-particles" class="absolute inset-0 w-full h-full pointer-events-none opacity-40" aria-hidden="true" style="z-index:0;"></canvas>
    <!-- Grid overlay -->
    <div class="absolute inset-0 grid-bg" style="z-index:1; pointer-events:none;"></div>

    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-32 grid md:grid-cols-2 gap-12 items-center" style="z-index:2;">

      <!-- Text column -->
      <div class="flex flex-col gap-6">
        <div class="tag w-fit">VesTech Research</div>
        <h1 class="text-4xl md:text-6xl font-black leading-tight" style="font-family:'Space Grotesk',sans-serif">
          <span class="text-[#e8f5e9]">Výzkum na</span><br/>
          <span class="glow-green" style="color:#00ff41">hraně technologií</span>
        </h1>
        <!-- Typewriter subtitle -->
        <p class="text-[#7ab87a] text-lg leading-relaxed">
          AI, QA, Fintech a DevOps — pohledem praktiků z <span id="typewriter" class="text-[#00ff41] font-semibold">první linie</span><span class="typewriter-cursor"></span>.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/blog" class="btn-primary">Číst blog →</a>
          <a href="/about" class="text-[#7ab87a] hover:text-[#00e5cc] transition-colors flex items-center gap-1 text-sm">
            O nás →
          </a>
        </div>
      </div>

      <!-- Living Guru avatar -->
      <div class="guru-container relative flex justify-center">
        <div class="guru-float relative w-64 h-64 md:w-80 md:h-80">

          <!-- Orbit rings (outermost first) -->
          <div class="orbit-ring-3 absolute rounded-full"
               style="inset:-62px; border:1px solid rgba(0,255,65,0.07);"></div>
          <div class="orbit-ring-2 absolute rounded-full"
               style="inset:-38px; border:1px dashed rgba(0,229,204,0.2);"></div>
          <div class="orbit-ring-1 absolute rounded-full"
               style="inset:-18px; border:1px solid rgba(0,255,65,0.28);"></div>

          <!-- Pulsing glow auras -->
          <div class="guru-glow-aura absolute inset-0 rounded-full blur-3xl"
               style="background:rgba(0,255,65,0.18); transform:scale(1.12);"></div>
          <div class="guru-glow-aura absolute inset-0 rounded-full blur-2xl"
               style="background:rgba(0,229,204,0.08); transform:scale(1.3); animation-delay:-1.75s;"></div>

          <!-- Main image with scanlines + holographic shimmer -->
          <div class="guru-img-wrapper guru-glow holo-shimmer relative w-full h-full rounded-full overflow-hidden border-2 border-[#00ff41]/35"
               style="box-shadow: 0 0 60px rgba(0,255,65,0.22), 0 0 100px rgba(0,229,204,0.1);">
            <img src="/images/guru-2.jpg" alt="VesTech Guru" class="w-full h-full object-cover" loading="eager" />
            <!-- Scanlines -->
            <div class="scanlines-overlay absolute inset-0"></div>
          </div>

        </div>
      </div>

    </div>
  </section>

  <!-- ===== FEATURED POSTS ===== -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold glow-green section-heading" style="color:#00ff41; font-family:'Space Grotesk',sans-serif">
      Nejnovější články
      <span class="animated-underline"></span>
    </h2>
    <div class="mb-8"></div>
    <div id="post-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {csPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          tags={post.data.tags}
          author={post.data.author}
          pubDate={post.data.pubDate}
          readTime={post.data.readTime}
          lang="cs"
        />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/blog" class="btn-primary">Všechny články →</a>
    </div>
  </section>

  <!-- ===== TOPICS ===== -->
  <section class="max-w-6xl mx-auto px-4 py-12 border-t border-green-900/20">
    <h2 class="text-xl font-bold mb-6 text-[#e8f5e9] section-heading" style="font-family:'Space Grotesk',sans-serif">
      Témata
      <span class="animated-underline"></span>
    </h2>
    <div id="topics-grid" class="flex flex-wrap gap-3">
      {topics.map(t => (
        <a href={`/blog?tag=${t}`} class="tag topic-tag hover:bg-[#00ff41]/15 transition-colors cursor-pointer">
          {t}
        </a>
      ))}
    </div>
  </section>

  <!-- ===== ABOUT SNIPPET ===== -->
  <section class="max-w-6xl mx-auto px-4 py-16 about-section">
    <div class="card-glass rounded-xl p-8 md:p-12 flex flex-col md:flex-row gap-8 items-center">
      <div class="w-24 h-24 rounded-full overflow-hidden border border-[#00ff41]/30 flex-shrink-0">
        <img src="/images/guru-3.jpg" alt="VesTech Guru" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="text-xl font-bold mb-3 text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
          Co je VesTech Research?
        </h2>
        <p class="text-[#7ab87a] leading-relaxed">
          Nezávislý výzkumný blog zaměřený na technologie, které mění způsob, jakým vyvíjíme a testujeme software.
          Píšeme o AI, QA, fintechu a DevOps z pohledu lidí, kteří s těmito technologiemi pracují denně.
        </p>
        <a href="/about" class="text-[#00e5cc] text-sm mt-3 inline-block hover:text-[#00ff41] transition-colors">
          Více o nás →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function () {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ── Tree-network canvas ── */
  (function () {
    var canvas = document.getElementById('hero-particles');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var mouse = { x: -9999, y: -9999 };
    var parallax = { x: 0, y: 0 };
    var branches = [], nodes = [], energyDots = [];
    var startTime = Date.now();

    var hero = canvas.parentElement;
    if (hero) {
      hero.addEventListener('mousemove', function (e) {
        var r = canvas.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      });
      hero.addEventListener('mouseleave', function () { mouse.x = -9999; mouse.y = -9999; });
    }

    function Branch(x, y, angle, length, depth, width) {
      this.x = x; this.y = y;
      this.angle = angle; this.length = length;
      this.depth = depth; this.width = width;
      var rad = angle * Math.PI / 180;
      this.ex = x + Math.cos(rad) * length;
      this.ey = y + Math.sin(rad) * length;
      var perp = (angle + 90) * Math.PI / 180;
      var bend = (Math.random() - 0.5) * length * 0.35;
      this.cx = (x + this.ex) / 2 + Math.cos(perp) * bend;
      this.cy = (y + this.ey) / 2 + Math.sin(perp) * bend;
      this.children = [];
    }

    function splitBranch(branch, maxDepth, spreadAngle, lengthDecay) {
      if (branch.depth >= maxDepth) {
        nodes.push({ x: branch.ex, y: branch.ey, phase: Math.random() * Math.PI * 2, r: Math.random() * 2.5 + 2.5 });
        return;
      }
      var numChildren = (branch.depth < 2 && Math.random() > 0.5) ? 3 : 2;
      var totalSpread = spreadAngle * (numChildren - 1);
      for (var i = 0; i < numChildren; i++) {
        var childAngle = branch.angle - totalSpread / 2 + i * spreadAngle + (Math.random() - 0.5) * 12;
        var childLength = branch.length * lengthDecay * (0.88 + Math.random() * 0.24);
        var childWidth = Math.max(0.4, branch.width * 0.65);
        var child = new Branch(branch.ex, branch.ey, childAngle, childLength, branch.depth + 1, childWidth);
        branch.children.push(child);
        branches.push(child);
        var numDots = branch.depth < 3 ? 2 : 1;
        for (var d = 0; d < numDots; d++) {
          energyDots.push({ branch: child, t: Math.random(), speed: 0.003 + Math.random() * 0.004 });
        }
        splitBranch(child, maxDepth, spreadAngle, lengthDecay);
      }
    }

    function generateTree() {
      branches = []; nodes = []; energyDots = [];
      var root = new Branch(canvas.width / 2, canvas.height + 50, -90, canvas.height * 0.35, 0, 2.5);
      branches.push(root);
      energyDots.push({ branch: root, t: 0, speed: 0.003 + Math.random() * 0.003 });
      energyDots.push({ branch: root, t: 0.4, speed: 0.003 + Math.random() * 0.003 });
      splitBranch(root, 5, 30, 0.65);
    }

    function resize() {
      var p = canvas.parentElement;
      canvas.width  = p ? p.offsetWidth  : window.innerWidth;
      canvas.height = p ? p.offsetHeight : 520;
      generateTree();
    }
    resize();
    window.addEventListener('resize', resize);

    function drawBranch(b) {
      var alpha = Math.max(0.15, 0.6 - b.depth * 0.07);
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = '#00ff41';
      ctx.lineWidth = b.width;
      ctx.beginPath();
      ctx.moveTo(b.x, b.y);
      if (b.depth % 2 === 0) {
        ctx.quadraticCurveTo(b.cx, b.cy, b.ex, b.ey);
      } else {
        ctx.lineTo(b.ex, b.ey);
      }
      ctx.stroke();
    }

    function drawNodes(t) {
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        var pulse = 0.4 + 0.6 * (0.5 + 0.5 * Math.sin(t * 0.002 + n.phase));
        var grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r * 3);
        grad.addColorStop(0, 'rgba(0,229,204,0.9)');
        grad.addColorStop(1, 'rgba(0,229,204,0)');
        ctx.globalAlpha = pulse;
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r * 3, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = pulse * 0.85;
        ctx.fillStyle = 'rgba(0,229,204,0.8)';
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function getBranchPoint(b, t) {
      if (b.depth % 2 === 0) {
        var mt = 1 - t;
        return { x: mt*mt*b.x + 2*mt*t*b.cx + t*t*b.ex, y: mt*mt*b.y + 2*mt*t*b.cy + t*t*b.ey };
      }
      return { x: b.x + (b.ex - b.x) * t, y: b.y + (b.ey - b.y) * t };
    }

    function drawEnergyDots() {
      for (var i = 0; i < energyDots.length; i++) {
        var dot = energyDots[i];
        dot.t += dot.speed;
        if (dot.t > 1.1) dot.t = 0;
        if (dot.t > 1) continue;
        var pt = getBranchPoint(dot.branch, dot.t);
        var fade = dot.t > 0.8 ? (1 - dot.t) / 0.2 : 1;
        ctx.globalAlpha = fade * 0.9;
        ctx.fillStyle = 'rgba(0,255,65,1)';
        ctx.beginPath(); ctx.arc(pt.x, pt.y, 2.2, 0, Math.PI * 2); ctx.fill();
        ctx.globalAlpha = fade * 0.4;
        ctx.fillStyle = 'rgba(0,255,65,0.6)';
        ctx.beginPath(); ctx.arc(pt.x, pt.y, 4.5, 0, Math.PI * 2); ctx.fill();
      }
    }

    if (reduced) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var bi = 0; bi < branches.length; bi++) drawBranch(branches[bi]);
      ctx.globalAlpha = 1;
      drawNodes(0);
      return;
    }

    function animate() {
      var t = Date.now() - startTime;
      var cx = canvas.width / 2, cy = canvas.height / 2;
      if (mouse.x !== -9999) {
        parallax.x += ((mouse.x - cx) * 0.02 - parallax.x) * 0.08;
        parallax.y += ((mouse.y - cy) * 0.01 - parallax.y) * 0.08;
      } else {
        parallax.x *= 0.95; parallax.y *= 0.95;
      }
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.save();
      ctx.translate(parallax.x, parallax.y);
      for (var bi = 0; bi < branches.length; bi++) drawBranch(branches[bi]);
      ctx.globalAlpha = 1;
      drawNodes(t);
      ctx.globalAlpha = 1;
      drawEnergyDots();
      ctx.restore();
      requestAnimationFrame(animate);
    }
    animate();
  })();

  /* ── Typewriter ── */
  (function () {
    var words = ['první linie', 'umělé inteligence', 'QA testování', 'fintechu', 'bezpečnosti'];
    var el = document.getElementById('typewriter');
    if (!el) return;
    if (reduced) { el.textContent = words[0]; return; }
    var wi = 0, ci = words[0].length, deleting = false;
    function tick() {
      var word = words[wi];
      if (!deleting) {
        el.textContent = word.slice(0, ci + 1);
        ci++;
        if (ci === word.length) { deleting = true; setTimeout(tick, 1600); return; }
      } else {
        el.textContent = word.slice(0, ci - 1);
        ci--;
        if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
      }
      setTimeout(tick, deleting ? 52 : 88);
    }
    setTimeout(tick, 2200);
  })();

  /* ── GSAP ScrollTrigger ── */
  (function () {
    if (reduced) return;
    if (typeof gsap === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('.section-heading').forEach(function (heading) {
      gsap.from(heading, { x: -35, opacity: 0, duration: 0.75, ease: 'power2.out',
        scrollTrigger: { trigger: heading, start: 'top 85%', once: true } });
      var line = heading.querySelector('.animated-underline');
      if (line) gsap.to(line, { scaleX: 1, duration: 0.8, delay: 0.3, ease: 'power2.out',
        scrollTrigger: { trigger: heading, start: 'top 85%', once: true } });
    });

    var postGrid = document.getElementById('post-grid');
    if (postGrid && postGrid.children.length) {
      gsap.from(Array.from(postGrid.children), { y: 45, opacity: 0, duration: 0.65,
        stagger: 0.13, ease: 'power2.out',
        scrollTrigger: { trigger: postGrid, start: 'top 85%', once: true } });
    }

    var topicsGrid = document.getElementById('topics-grid');
    if (topicsGrid && topicsGrid.children.length) {
      gsap.from(Array.from(topicsGrid.children), { scale: 0.4, opacity: 0, duration: 0.38,
        stagger: 0.07, ease: 'back.out(2.2)',
        scrollTrigger: { trigger: topicsGrid, start: 'top 90%', once: true } });
    }

    var aboutCard = document.querySelector('.about-section .card-glass');
    if (aboutCard) {
      gsap.from(aboutCard, { y: 30, opacity: 0, scale: 0.96, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: aboutCard, start: 'top 88%', once: true } });
    }
  })();
})();
</script>
