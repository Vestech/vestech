---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const csPosts = allPosts
  .filter(p => p.data.lang === 'cs')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const topics = ['AI', 'QA', 'Fintech', 'DevOps', 'Security', 'Testing', 'Automation'];
---
<BaseLayout title="Výzkum na hraně technologií" lang="cs">
  <!-- Hero -->
  <section class="grid-bg relative overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 py-20 md:py-32 grid md:grid-cols-2 gap-12 items-center">
      <!-- Text -->
      <div class="flex flex-col gap-6">
        <div class="tag w-fit">VesTech Research</div>
        <h1 class="text-4xl md:text-6xl font-black leading-tight" style="font-family:'Space Grotesk',sans-serif">
          <span class="text-[#e8f5e9]">Výzkum na</span><br/>
          <span class="glow-green" style="color:#00ff41">hraně technologií</span>
        </h1>
        <p class="text-[#7ab87a] text-lg leading-relaxed">
          AI, QA, Fintech a DevOps — pohledem praktiků z první linie.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/blog" class="btn-primary">Číst blog →</a>
          <a href="/about" class="text-[#7ab87a] hover:text-[#00e5cc] transition-colors flex items-center gap-1 text-sm">
            O nás →
          </a>
        </div>
      </div>

      <!-- Guru image -->
      <div class="relative flex justify-center">
        <div class="relative w-64 h-64 md:w-80 md:h-80">
          <!-- Glow behind -->
          <div class="absolute inset-0 rounded-full bg-[#00ff41]/10 blur-3xl scale-110"></div>
          <div class="absolute inset-0 rounded-full bg-[#00e5cc]/5 blur-2xl scale-125"></div>
          <!-- Image -->
          <div class="relative w-full h-full rounded-full overflow-hidden border-2 border-[#00ff41]/30"
               style="box-shadow: 0 0 60px rgba(0,255,65,0.2), 0 0 120px rgba(0,229,204,0.1)">
            <img src="/images/guru-2.jpg" alt="VesTech Guru" class="w-full h-full object-cover" />
          </div>
          <!-- Orbit ring -->
          <div class="absolute inset-[-10px] rounded-full border border-[#00ff41]/10 animate-spin"
               style="animation-duration: 20s;"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured posts -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold mb-8 glow-green" style="color:#00ff41; font-family:'Space Grotesk',sans-serif">
      Nejnovější články
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {csPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          tags={post.data.tags}
          author={post.data.author}
          pubDate={post.data.pubDate}
          readTime={post.data.readTime}
          lang="cs"
        />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/blog" class="btn-primary">Všechny články →</a>
    </div>
  </section>

  <!-- Topics -->
  <section class="max-w-6xl mx-auto px-4 py-12 border-t border-green-900/20">
    <h2 class="text-xl font-bold mb-6 text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
      Témata
    </h2>
    <div class="flex flex-wrap gap-3">
      {topics.map(t => (
        <a href={`/blog?tag=${t}`} class="tag hover:bg-[#00ff41]/15 transition-colors cursor-pointer">
          {t}
        </a>
      ))}
    </div>
  </section>

  <!-- About snippet -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="card-glass rounded-xl p-8 md:p-12 flex flex-col md:flex-row gap-8 items-center">
      <div class="w-24 h-24 rounded-full overflow-hidden border border-[#00ff41]/30 flex-shrink-0">
        <img src="/images/guru-3.jpg" alt="VesTech Guru" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="text-xl font-bold mb-3 text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
          Co je VesTech Research?
        </h2>
        <p class="text-[#7ab87a] leading-relaxed">
          Nezávislý výzkumný blog zaměřený na technologie, které mění způsob, jakým vyvíjíme a testujeme software.
          Píšeme o AI, QA, fintechu a DevOps z pohledu lidí, kteří s těmito technologiemi pracují denně.
        </p>
        <a href="/about" class="text-[#00e5cc] text-sm mt-3 inline-block hover:text-[#00ff41] transition-colors">
          Více o nás →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
