---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Výzkum na hraně technologií" lang="cs">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden min-h-[70vh] md:min-h-[78vh] flex items-start">
    <div class="absolute inset-0 pointer-events-none" style="background-image:url('/images/hero-tree-tech.jpg'); background-size:cover; background-position:center center;"></div>
    <div class="absolute inset-0 pointer-events-none" style="background:
      linear-gradient(90deg, rgba(2,8,7,0.68) 0%, rgba(2,8,7,0.42) 34%, rgba(2,8,7,0.16) 58%, rgba(2,8,7,0.08) 100%),
      linear-gradient(180deg, rgba(2,8,7,0.22) 0%, rgba(2,8,7,0.08) 32%, rgba(2,8,7,0.32) 100%);"></div>
    <div class="absolute inset-0 grid-bg opacity-10 pointer-events-none"></div>
        <div class="relative z-10 w-full max-w-6xl mx-auto px-6 pt-14 pb-20 md:px-10 md:pt-20 md:pb-24 lg:px-14 lg:pt-24 lg:pb-28">
      <div class="max-w-2xl">
        <div class="tag w-fit mb-5">VesTech Research</div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight mb-6" style="font-family:'Space Grotesk',sans-serif">
          <span class="text-[#f2fff3]">Výzkum na</span><br/>
          <span class="glow-green" style="color:#00ff41">hraně technologií</span>
        </h1>
        <p class="text-[#d7f5d9] text-lg md:text-xl leading-relaxed max-w-xl mb-8 drop-shadow-[0_2px_20px_rgba(0,0,0,0.45)]">
          AI, QA, Fintech a DevOps — pohledem praktiků z <span id="typewriter" class="text-[#00ff41] font-semibold">první linie</span><span class="typewriter-cursor"></span>.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/blog" class="btn-primary">Číst blog →</a>
          <a href="/about" class="text-[#d7f5d9] hover:text-[#00e5cc] transition-colors flex items-center gap-1 text-sm md:text-base">
            O nás →
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function () {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;


  /* ── Typewriter ── */
  (function () {
    var words = ['první linie', 'umělé inteligence', 'QA testování', 'fintechu', 'bezpečnosti'];
    var el = document.getElementById('typewriter');
    if (!el) return;
    if (reduced) { el.textContent = words[0]; return; }
    var wi = 0, ci = words[0].length, deleting = false;
    function tick() {
      var word = words[wi];
      if (!deleting) {
        el.textContent = word.slice(0, ci + 1);
        ci++;
        if (ci === word.length) { deleting = true; setTimeout(tick, 1600); return; }
      } else {
        el.textContent = word.slice(0, ci - 1);
        ci--;
        if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
      }
      setTimeout(tick, deleting ? 52 : 88);
    }
    setTimeout(tick, 2200);
  })();
})();
</script>
