---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout title="Blog" lang="en">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center gap-4 mb-10">
      <h1 class="text-4xl font-black glow-green" style="color:#00ff41; font-family:'Space Grotesk',sans-serif">Blog</h1>
      <span class="tag">{posts.length} {posts.length === 1 ? 'article' : 'articles'}</span>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          tags={post.data.tags}
          author={post.data.author}
          pubDate={post.data.pubDate}
          readTime={post.data.readTime}
          lang="en"
        />
      ))}
    </div>
  </section>
</BaseLayout>
