---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const enPosts = allPosts
  .filter(p => p.data.lang === 'en')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const topics = ['AI', 'QA', 'Fintech', 'DevOps', 'Security', 'Testing', 'Automation'];
---
<BaseLayout title="Research at the edge of technology" lang="en">

  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden px-4 pt-8 md:pt-12">
    <div class="absolute inset-0 pointer-events-none" style="background:
      radial-gradient(circle at 14% 20%, rgba(0,255,65,0.10), transparent 24%),
      radial-gradient(circle at 84% 18%, rgba(0,229,204,0.12), transparent 26%),
      linear-gradient(180deg, rgba(2,8,7,0.96) 0%, rgba(3,8,9,0.92) 55%, rgba(2,5,6,0.98) 100%);"></div>

    <div class="relative max-w-6xl mx-auto overflow-hidden rounded-[2rem] border border-[#00ff41]/12 bg-[#050a0a]/90 shadow-[0_0_0_1px_rgba(0,255,65,0.04),0_30px_120px_rgba(0,0,0,0.55)]">
      <div class="absolute inset-0 pointer-events-none" style="background-image:url('/images/hero-tree-tech.jpg'); background-size:cover; background-position:center right;"></div>
      <div class="absolute inset-0 pointer-events-none" style="background:
        linear-gradient(90deg, rgba(3,7,8,0.97) 0%, rgba(3,7,8,0.94) 34%, rgba(3,7,8,0.70) 56%, rgba(3,7,8,0.30) 74%, rgba(3,7,8,0.58) 100%),
        linear-gradient(180deg, rgba(3,7,8,0.28) 0%, rgba(3,7,8,0.12) 38%, rgba(3,7,8,0.26) 100%);"></div>
      <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none"></div>
      <canvas data-circuit-flow class="absolute inset-y-0 right-0 w-[56%] h-full pointer-events-none opacity-95" aria-hidden="true"></canvas>
      <div class="absolute inset-y-0 right-0 w-[56%] pointer-events-none" style="background:linear-gradient(90deg, rgba(3,7,8,0.0) 0%, rgba(0,255,65,0.03) 34%, rgba(0,229,204,0.06) 100%);"></div>

      <div class="relative z-10 grid md:grid-cols-[0.96fr_1.04fr] gap-8 items-center px-6 py-12 md:px-10 md:py-16 lg:px-14 lg:py-20">
        <div class="flex flex-col gap-6 max-w-xl">
          <div class="tag w-fit">VesTech Research</div>
          <h1 class="text-4xl md:text-6xl font-black leading-tight" style="font-family:'Space Grotesk',sans-serif">
            <span class="text-[#e8f5e9]">Research at the</span><br/>
            <span class="glow-green" style="color:#00ff41">edge of technology</span>
          </h1>
          <p class="text-[#9bcaa0] text-lg leading-relaxed max-w-lg">
            AI, QA, Fintech &amp; DevOps — insights from <span id="typewriter" class="text-[#00ff41] font-semibold">the front line</span><span class="typewriter-cursor"></span>.
          </p>
          <div class="flex gap-4 flex-wrap">
            <a href="/en/blog" class="btn-primary">Read the blog →</a>
            <a href="/en/about" class="text-[#7ab87a] hover:text-[#00e5cc] transition-colors flex items-center gap-1 text-sm">
              About us →
            </a>
          </div>
        </div>

        <div class="relative min-h-[21rem] md:min-h-[30rem]">
          <div class="absolute inset-y-[7%] right-[4%] w-[78%] rounded-[2rem] border border-[#00ff41]/10 bg-[rgba(3,10,10,0.12)] backdrop-blur-[1px] shadow-[inset_0_0_80px_rgba(0,255,65,0.05),0_0_120px_rgba(0,229,204,0.10)]"></div>
          <div class="absolute right-[8%] top-[10%] h-32 w-32 rounded-full blur-3xl" style="background:rgba(0,255,65,0.14);"></div>
          <div class="absolute right-[20%] bottom-[12%] h-40 w-40 rounded-full blur-3xl" style="background:rgba(0,229,204,0.10);"></div>

          <div class="guru-float absolute bottom-0 left-[4%] md:left-[6%] w-[44%] max-w-[14rem] md:max-w-[16rem] z-10">
            <div class="relative overflow-hidden rounded-[1.5rem] border border-[#00ff41]/18 bg-[#040908] shadow-[0_0_50px_rgba(0,255,65,0.12),0_18px_60px_rgba(0,0,0,0.42)]">
              <img src="/images/guru-2.jpg" alt="VesTech Guru" class="w-full h-full object-cover object-center" loading="eager" />
              <div class="scanlines-overlay absolute inset-0"></div>
              <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(0,0,0,0.04), rgba(0,0,0,0.24));"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED POSTS ===== -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold glow-green section-heading" style="color:#00ff41; font-family:'Space Grotesk',sans-serif">
      Latest articles
      <span class="animated-underline"></span>
    </h2>
    <div class="mb-8"></div>
    <div id="post-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {enPosts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          slug={post.id}
          tags={post.data.tags}
          author={post.data.author}
          pubDate={post.data.pubDate}
          readTime={post.data.readTime}
          lang="en"
        />
      ))}
    </div>
    <div class="text-center mt-10">
      <a href="/en/blog" class="btn-primary">All articles →</a>
    </div>
  </section>

  <!-- ===== TOPICS ===== -->
  <section class="max-w-6xl mx-auto px-4 py-12 border-t border-green-900/20">
    <h2 class="text-xl font-bold mb-6 text-[#e8f5e9] section-heading" style="font-family:'Space Grotesk',sans-serif">
      Topics
      <span class="animated-underline"></span>
    </h2>
    <div id="topics-grid" class="flex flex-wrap gap-3">
      {topics.map(t => (
        <a href={`/en/blog?tag=${t}`} class="tag topic-tag hover:bg-[#00ff41]/15 transition-colors cursor-pointer">
          {t}
        </a>
      ))}
    </div>
  </section>

  <!-- ===== ABOUT SNIPPET ===== -->
  <section class="max-w-6xl mx-auto px-4 py-16 about-section">
    <div class="card-glass rounded-xl p-8 md:p-12 flex flex-col md:flex-row gap-8 items-center">
      <div class="w-24 h-24 rounded-full overflow-hidden border border-[#00ff41]/30 flex-shrink-0">
        <img src="/images/guru-3.jpg" alt="VesTech Guru" class="w-full h-full object-cover" />
      </div>
      <div>
        <h2 class="text-xl font-bold mb-3 text-[#e8f5e9]" style="font-family:'Space Grotesk',sans-serif">
          What is VesTech Research?
        </h2>
        <p class="text-[#7ab87a] leading-relaxed">
          An independent research blog focused on technologies that are changing the way we develop and test software.
          We write about AI, QA, fintech and DevOps from the perspective of practitioners who work with these technologies daily.
        </p>
        <a href="/en/about" class="text-[#00e5cc] text-sm mt-3 inline-block hover:text-[#00ff41] transition-colors">
          More about us →
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
(function () {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;


  /* ── Circuit electron flow ── */
  (function () {
    var canvases = document.querySelectorAll('[data-circuit-flow]');
    if (!canvases.length) return;

    function initCircuitFlow(canvas) {
      var ctx = canvas.getContext('2d');
      if (!ctx) return;
      var frame = null;
      var paths = [];
      var electrons = [];

      function makePath(points) {
        var segments = [];
        var total = 0;
        for (var i = 0; i < points.length - 1; i++) {
          var a = points[i], b = points[i + 1];
          var len = Math.hypot(b.x - a.x, b.y - a.y);
          segments.push({ a: a, b: b, len: len, start: total });
          total += len;
        }
        return { points: points, segments: segments, total: total };
      }

      function pointOnPath(path, t) {
        var d = (t % 1 + 1) % 1 * path.total;
        for (var i = 0; i < path.segments.length; i++) {
          var s = path.segments[i];
          if (d <= s.start + s.len || i === path.segments.length - 1) {
            var local = s.len ? (d - s.start) / s.len : 0;
            return {
              x: s.a.x + (s.b.x - s.a.x) * local,
              y: s.a.y + (s.b.y - s.a.y) * local
            };
          }
        }
        return path.points[0];
      }

      function buildPaths(w, h) {
        var p = function (x, y) { return { x: w * x, y: h * y }; };
        paths = [
          makePath([p(0.56,0.10), p(0.56,0.34), p(0.42,0.34), p(0.42,0.56), p(0.32,0.56), p(0.32,0.82)]),
          makePath([p(0.74,0.12), p(0.74,0.40), p(0.64,0.40), p(0.64,0.66), p(0.52,0.66), p(0.52,0.90)]),
          makePath([p(0.34,0.18), p(0.34,0.32), p(0.22,0.32), p(0.22,0.50), p(0.12,0.50)]),
          makePath([p(0.58,0.24), p(0.46,0.24), p(0.46,0.46), p(0.36,0.46), p(0.36,0.70)]),
          makePath([p(0.44,0.64), p(0.62,0.64), p(0.62,0.82), p(0.82,0.82)]),
          makePath([p(0.26,0.58), p(0.26,0.18), p(0.16,0.18)]),
          makePath([p(0.48,0.48), p(0.78,0.48)]),
          makePath([p(0.18,0.76), p(0.44,0.76), p(0.44,0.92)]),
          makePath([p(0.66,0.28), p(0.90,0.28)]),
          makePath([p(0.60,0.54), p(0.88,0.54)])
        ];

        electrons = [];
        for (var i = 0; i < paths.length; i++) {
          var count = i < 4 ? 3 : 2;
          for (var j = 0; j < count; j++) {
            electrons.push({
              pathIndex: i,
              t: (j / count) + Math.random() * 0.18,
              speed: 0.0018 + Math.random() * 0.0028,
              size: 1.6 + Math.random() * 1.5,
              hue: j % 2 === 0 ? 'green' : 'cyan'
            });
          }
        }
      }

      function resize() {
        var rect = canvas.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, Math.round(rect.width * dpr));
        canvas.height = Math.max(1, Math.round(rect.height * dpr));
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        buildPaths(rect.width, rect.height);
        draw(0, true);
      }

      function drawNodes(path) {
        for (var i = 0; i < path.points.length; i++) {
          var point = path.points[i];
          var r = i === path.points.length - 1 ? 3.2 : 2.1;
          var grad = ctx.createRadialGradient(point.x, point.y, 0, point.x, point.y, r * 4);
          grad.addColorStop(0, 'rgba(0,229,204,0.95)');
          grad.addColorStop(0.45, 'rgba(0,255,65,0.35)');
          grad.addColorStop(1, 'rgba(0,229,204,0)');
          ctx.fillStyle = grad;
          ctx.beginPath();
          ctx.arc(point.x, point.y, r * 4, 0, Math.PI * 2);
          ctx.fill();
          ctx.fillStyle = i === path.points.length - 1 ? 'rgba(0,229,204,0.88)' : 'rgba(0,255,65,0.55)';
          ctx.beginPath();
          ctx.arc(point.x, point.y, r, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      function draw(ts, staticOnly) {
        var rect = canvas.getBoundingClientRect();
        ctx.clearRect(0, 0, rect.width, rect.height);
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        for (var i = 0; i < paths.length; i++) {
          var path = paths[i];
          ctx.strokeStyle = 'rgba(0,255,65,0.17)';
          ctx.lineWidth = i < 2 ? 2.4 : 1.7;
          ctx.beginPath();
          ctx.moveTo(path.points[0].x, path.points[0].y);
          for (var j = 1; j < path.points.length; j++) ctx.lineTo(path.points[j].x, path.points[j].y);
          ctx.stroke();

          ctx.strokeStyle = 'rgba(0,229,204,0.07)';
          ctx.lineWidth = Math.max(1, (i < 2 ? 2.4 : 1.7) + 3.5);
          ctx.beginPath();
          ctx.moveTo(path.points[0].x, path.points[0].y);
          for (var k = 1; k < path.points.length; k++) ctx.lineTo(path.points[k].x, path.points[k].y);
          ctx.stroke();
          drawNodes(path);
        }

        if (!staticOnly) {
          for (var e = 0; e < electrons.length; e++) {
            var electron = electrons[e];
            electron.t += electron.speed;
            var point = pointOnPath(paths[electron.pathIndex], electron.t);
            var outer = electron.size * 4.8;
            var g = ctx.createRadialGradient(point.x, point.y, 0, point.x, point.y, outer);
            if (electron.hue === 'cyan') {
              g.addColorStop(0, 'rgba(173,255,247,0.95)');
              g.addColorStop(0.4, 'rgba(0,229,204,0.45)');
              g.addColorStop(1, 'rgba(0,229,204,0)');
              ctx.fillStyle = g;
              ctx.beginPath(); ctx.arc(point.x, point.y, outer, 0, Math.PI * 2); ctx.fill();
              ctx.fillStyle = 'rgba(197,255,250,0.98)';
            } else {
              g.addColorStop(0, 'rgba(209,255,214,0.95)');
              g.addColorStop(0.35, 'rgba(0,255,65,0.5)');
              g.addColorStop(1, 'rgba(0,255,65,0)');
              ctx.fillStyle = g;
              ctx.beginPath(); ctx.arc(point.x, point.y, outer, 0, Math.PI * 2); ctx.fill();
              ctx.fillStyle = 'rgba(236,255,239,0.98)';
            }
            ctx.beginPath();
            ctx.arc(point.x, point.y, electron.size, 0, Math.PI * 2);
            ctx.fill();
          }
        }
      }

      resize();
      window.addEventListener('resize', resize);
      if (reduced) return;
      function animate(ts) {
        draw(ts, false);
        frame = requestAnimationFrame(animate);
      }
      frame = requestAnimationFrame(animate);
    }

    canvases.forEach(initCircuitFlow);
  })();

  /* ── Typewriter ── */
  (function () {
    var words = ['the front line', 'artificial intelligence', 'QA testing', 'fintech', 'security'];
    var el = document.getElementById('typewriter');
    if (!el) return;
    if (reduced) { el.textContent = words[0]; return; }
    var wi = 0, ci = words[0].length, deleting = false;
    function tick() {
      var word = words[wi];
      if (!deleting) {
        el.textContent = word.slice(0, ci + 1);
        ci++;
        if (ci === word.length) { deleting = true; setTimeout(tick, 1600); return; }
      } else {
        el.textContent = word.slice(0, ci - 1);
        ci--;
        if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
      }
      setTimeout(tick, deleting ? 52 : 88);
    }
    setTimeout(tick, 2200);
  })();

  /* ── GSAP ScrollTrigger ── */
  (function () {
    if (reduced) return;
    if (typeof gsap === 'undefined') return;
    gsap.registerPlugin(ScrollTrigger);

    document.querySelectorAll('.section-heading').forEach(function (heading) {
      gsap.from(heading, { x: -35, opacity: 0, duration: 0.75, ease: 'power2.out',
        scrollTrigger: { trigger: heading, start: 'top 85%', once: true } });
      var line = heading.querySelector('.animated-underline');
      if (line) gsap.to(line, { scaleX: 1, duration: 0.8, delay: 0.3, ease: 'power2.out',
        scrollTrigger: { trigger: heading, start: 'top 85%', once: true } });
    });

    var postGrid = document.getElementById('post-grid');
    if (postGrid && postGrid.children.length) {
      gsap.from(Array.from(postGrid.children), { y: 45, opacity: 0, duration: 0.65,
        stagger: 0.13, ease: 'power2.out',
        scrollTrigger: { trigger: postGrid, start: 'top 85%', once: true } });
    }

    var topicsGrid = document.getElementById('topics-grid');
    if (topicsGrid && topicsGrid.children.length) {
      gsap.from(Array.from(topicsGrid.children), { scale: 0.4, opacity: 0, duration: 0.38,
        stagger: 0.07, ease: 'back.out(2.2)',
        scrollTrigger: { trigger: topicsGrid, start: 'top 90%', once: true } });
    }

    var aboutCard = document.querySelector('.about-section .card-glass');
    if (aboutCard) {
      gsap.from(aboutCard, { y: 30, opacity: 0, scale: 0.96, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: aboutCard, start: 'top 88%', once: true } });
    }
  })();
})();
</script>
