---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'cs' | 'en';
  noIndex?: boolean;
}

const {
  title,
  description = 'VesTech Research — výzkum na hraně technologií',
  lang = 'cs',
  noIndex = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title} | VesTech Research</title>
    <link rel="icon" type="image/jpeg" href="/images/guru-1.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Boot overlay: terminal-style startup sequence -->
    <div id="boot-overlay" aria-hidden="true">
      <div id="boot-text" style="text-align:left; max-width:420px; line-height:2.2; font-size:0.85rem; color:#00ff41;"></div>
    </div>

    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <script is:inline>
    (function () {
      var overlay = document.getElementById('boot-overlay');
      var textEl = document.getElementById('boot-text');
      if (!overlay || !textEl) return;

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        overlay.remove();
        return;
      }

      var bootSeen = false;
      try {
        bootSeen = localStorage.getItem('vestech.bootSeen') === '1';
      } catch (e) {}

      if (bootSeen) {
        overlay.remove();
        return;
      }

      try {
        localStorage.setItem('vestech.bootSeen', '1');
      } catch (e) {}

      var lines = [
        '> VesTech Research v2.6.0',
        '> Loading AI modules... <span style="color:#00e5cc">OK</span>',
        '> Welcome, researcher.'
      ];
      var i = 0;
      function showLine() {
        if (i >= lines.length) {
          setTimeout(function () {
            overlay.classList.add('boot-gone');
            setTimeout(function () { if (overlay.parentNode) overlay.parentNode.removeChild(overlay); }, 500);
          }, 300);
          return;
        }
        textEl.innerHTML += lines[i] + '<br>';
        i++;
        setTimeout(showLine, 165);
      }
      showLine();
    })();
    </script>
  </body>
</html>
